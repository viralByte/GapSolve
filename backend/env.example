# Choose which LLM provider to use: "anthropic" or "gemini"
LLM_PROVIDER=anthropic

# Required if LLM_PROVIDER=anthropic
# Get a key at https://console.anthropic.com (new accounts get ~$5 free trial credit)
ANTHROPIC_API_KEY=your_key_here

# Optional: switch to Google's free-tier Gemini API instead of Claude.
# Set LLM_PROVIDER=gemini and fill in GEMINI_API_KEY (get one free, no card,
# at https://aistudio.google.com/apikey). Leave as "anthropic" to use Claude.
LLM_PROVIDER=anthropic
GEMINI_API_KEY=your_gemini_key_here

# Required if LLM_PROVIDER=gemini
# Get a key at https://aistudio.google.com/apikey (genuine ongoing free tier, rate-limited)
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.5-flash
